{% extends "cp/_cp_layout.html.twig" %}

{% set page_title = 'Account Settings' %}

{% block page %}

{% include 'core/_breadcrumb.html.twig' with {
  items: [
    { label: 'Control Panel', url: '/account' },
    { label: 'Account Settings' }
  ]
} %}

{# Change Avatar #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Avatar</h2>
    </div>
    <div class="content-body">

        <div class="d-flex">

            <div class="account-settings-avatar">
                {% if user.avatar %}
                    <img src="/avatar/{{ user.avatar }}" />
                    {% else %}
                    <img src="/avatar-generate/256/{{ user.username|url_encode }}.png" />
                {% endif %}
            </div>

            <div>

                <form action="/account/avatar" method="POST" enctype="multipart/form-data" style="margin-bottom: 20px;">

                    <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
                    <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

                    <div class="form-group">
                        <label for="avatar">
                            New avatar
                        </label>
                        <input type="file" class="form-control" id="avatar" name="avatar">
                    </div>

                    <div class="form-group mt-1">
                        <span class="text-muted" style="font-size: 12px;">Maximum filesize: {{ globals.upload_limit.avatar.formatted }}</span>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-medieval">Submit</button>
                    </div>

                </form>

                {% if user.avatar %}
                    <a href="/account/remove-avatar/{{ csrf.name }}/{{ csrf.value|url_encode }}">Remove current avatar</a>
                {% endif %}

            </div>

        </div>

    </div>
</div>

{# Country #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Country</h2>
    </div>
    <div class="content-body">
        <form action="/account/country" method="POST">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <div class="form-group" style="max-width: 400px;">
                <select id="country" class="form-control form-select" name="country">
                    <option value="">Not specified (Hidden)</option>
                    {% for country_code in country_codes %}
                        <option value="{{ country_code }}" {% if user.country is not null and user.country == country_code %}selected=selected{% endif %}>
                            {{ get_country_emoji(country_code) }} &nbsp; {{ get_country_string(country_code) }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update</button>
            </div>

        </form>
    </div>
</div>

{# Change Email Address #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Email Address</h2>
    </div>
    <div class="content-body">

        <form action="/account/email" method="POST">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <p class="mt-2 mb-4">
                {% if user.email %}
                    Email address:
                    <strong style="margin-left: 20px;">{{ user.email }}</strong>
                    {% if user.isEmailVerified %}
                        <span class="badge bg-success">Verified</span>
                    {% else %}
                        <span class="badge bg-danger">Not verified</span>
                        <span class="text-muted mx-2">&bullet;</span>
                        <a href="/account/resend-verification-email/{{ csrf.name }}/{{ csrf.value|url_encode }}">Resend verification mail</a>
                    {% endif %}
                    <span class="text-muted mx-2">&bullet;</span>
                    <a href="/account/remove-email/{{ csrf.name }}/{{ csrf.value|url_encode }}">Remove</a>
                {% else %}
                    There is no email address linked to your account.
                {% endif %}
            </p>

            <div class="form-group" style="max-width: 400px;">
                <label for="new_email_address">
                    New email address
                </label>
                <input type="email" class="form-control" id="new_email_address" name="new_email_address" required />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update Email Address</button>
            </div>

        </form>
    </div>
</div>

{# About Me #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>About Me</h2>
    </div>
    <div class="content-body">
        <form action="/account/about-me" method="POST">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <div class="form-group">
                <textarea class="form-control mb-1" name="about_me" rows="6">{% if user.bio is not null and user.bio.bio is not empty %}{{ user.bio.bio }}{% endif %}</textarea>
                <span class="text-muted mx-2" style="font-size: 12px;">
                    Markdown and spoilers supported.
                    <a href="#" data-markdown-format-info-link="true">
                        More info
                    </a>
                </span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update</button>
            </div>

        </form>
    </div>
</div>

{# Change Theme #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Website Theme</h2>
    </div>
    <div class="content-body">
        <form action="/account/theme" method="POST">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <div class="form-group" style="max-width: 400px;">
                <select id="theme_id" class="form-control form-select" name="theme_id">
                    {% for theme in website_theme.all %}
                        <option value="{{ theme.id }}" {% if website_theme.current.id is not null and website_theme.current.id == theme.id %}selected=selected{% endif %}>
                            {{ theme.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update</button>
            </div>

        </form>
    </div>
</div>


{# Change CDN #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Download Server (CDN)</h2>
    </div>
    <div class="content-body">
        <form action="/account/cdn" method="POST">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <div class="form-group" style="max-width: 400px;">

                {% for endpoint_id, endpoint_data in cdn.all %}

                    <div class="select-cdn-box">
                        <div class="select-cdn-box-left">
                            <input class="form-check-input" type="radio" name="cdn" value="{{ endpoint_id }}" {% if cdn.current == endpoint_id %}checked{% endif %}>
                        </div>
                        <div class="select-cdn-box-right w-100">
                            <strong>{{ endpoint_data.name }}</strong>
                            {# <div class="w-100 d-flex justify-content-between"> #}
                            <div class="w-100">
                                <span class="text-muted">{{ endpoint_data.location }}</span>
                                {# <span class="" id="cdn-speedtest-speed-{{ endpoint_id }}"></span> #}
                                <span class="ms-3" id="cdn-speedtest-speed-{{ endpoint_id }}"></span>
                            </div>
                        </div>
                    </div>

                {% endfor %}

            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update</button>
                <button type="button" class="btn btn-medieval btn-medieval-black" id="cdn-speedtest" style="display:none">Speedtest</button>
                <span class="ms-3" id="cdn-speedtest-status"></span>
            </div>

        </form>
    </div>
</div>

{# Change Password #}
<div class="content-box bg-keeper bd-keeper">
    <div class="content-header">
        <h2>Password</h2>
    </div>
    <div class="content-body">

        <form action="/account/password" method="POST" style="max-width: 400px;">

            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

            <div class="form-group">
                <label for="current_password">
                    Current Password
                </label>
                <input type="password" class="form-control" id="current_password" name="current_password" required />
            </div>

            <div class="form-group">
                <label for="new_password">
                    New Password
                </label>
                <input type="password" class="form-control" id="new_password" name="new_password" autocomplete="off" required />
            </div>

            <div class="form-group">
                <label for="repeat_password">
                    Repeat new Password
                </label>
                <input type="password" class="form-control" id="repeat_password" name="repeat_password" autocomplete="off" required />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-medieval">Update Password</button>
            </div>

        </form>

    </div>
</div>

{% include 'markdown.format.html.twig' %}

{% endblock %}


{% block body_javascript %}
    <script>
        var cdn_endpoints = {{ cdn.all|json_encode()|raw }} ;
    </script>
    <script>
        $(function(e){
            // Avatar max upload filesize check
            $('#avatar').on('change', function(){
                if(this.files[0].size > app_store.upload_limit.avatar.size){
                    toastr.warning('Avatar exceeds maximum filesize of ' + app_store.upload_limit.avatar.formatted);
                    this.value = null;
                }
            });

            // Allow clicking on the CDN boxes to select them (JS only)
            $('.select-cdn-box').addClass('select-cdn-box-hover');
            $('.select-cdn-box').on('click', function(e){
                if (e.target.type === 'radio') {
                    return;
                }
                e.preventDefault();
                e.stopPropagation();
                // Uncheck all radio inputs with name="cdn"
                $('input[name="cdn"]').prop('checked', false);
                // Check the radio input inside the clicked box
                $(this).closest('.select-cdn-box').find('input[type="radio"]').prop('checked', true);
            });

            // Speed test

            $('#cdn-speedtest').show();
            $('#cdn-speedtest').on('click', async function(e){

                // Show user we are testing the speed
                $(this).buttonLoader(true);
                $('#cdn-speedtest-status').text('Testing download speeds...');

                // Clear older speeds
                $('[id^=cdn-speedtest-speed]').removeClass('text-success').removeClass('text-danger').text('');

                const speedTestFile = "/speedtest/10MiB.speedtest.bin";
                const speedTestFileSize = 10485760;

                async function testTransferSpeed(url, maxDownloadDuration = 5, connectionTimeout = 5000) {
                    const startTime = performance.now();
                    let downloadedBytes = 0;

                    const controller = new AbortController();
                    let abortReason = null; // State variable for browser compatibility

                    const connectTimer = setTimeout(() => {
                        abortReason = "connection_timeout";
                        controller.abort();
                    }, connectionTimeout);

                    try {
                        const response = await fetch(url, {
                            signal: controller.signal,
                            cache: 'no-store',
                            mode: 'cors'
                        });

                        clearTimeout(connectTimer);

                        if (!response.ok) {
                            return { url, speedMBps: 0, duration: -1, downloadedBytes: 0 };
                        }

                        const downloadTimer = setTimeout(() => {
                            abortReason = "download_timeout";
                            controller.abort();
                        }, maxDownloadDuration * 1000);

                        const reader = response.body.getReader();
                        while (true) {
                            const { done, value } = await reader.read();
                            if (done) break;
                            downloadedBytes += value.length;
                        }

                        clearTimeout(downloadTimer);

                        const endTime = performance.now();
                        const duration = (endTime - startTime) / 1000;
                        const speedMBps = (downloadedBytes / (1024 * 1024)) / duration;

                        return { url, speedMBps, duration, downloadedBytes };

                    } catch (error) {
                        const endTime = performance.now();
                        const duration = (endTime - startTime) / 1000;

                        if (error.name === 'AbortError' || controller.signal.aborted) {
                            if (abortReason === "connection_timeout") {
                                return { url, speedMBps: 0, duration: Infinity, downloadedBytes: 0 };
                            }

                            if (abortReason === "download_timeout") {
                                console.log(`[SpeedTest] 5s up. JS actually received: ${downloadedBytes} bytes.`);
                                const speedMBps = (downloadedBytes / (1024 * 1024)) / duration;
                                return { url, speedMBps, duration, downloadedBytes };
                            }
                        }

                        console.error(`Request failed for ${url}:`, error);
                        return { url, speedMBps: 0, duration: -1, downloadedBytes: 0 };
                    }
                }

                var bestEndpoint;
                var bestSpeed = 0;

                for (const id in cdn_endpoints) {
                    const data = cdn_endpoints[id];

                    // Test the download speed for this endpoint
                    $('#cdn-speedtest-status').text(`Testing ${data.name}...`);
                    const result = await testTransferSpeed(data.url + speedTestFile);

                    if(result.duration == -1){
                        $('#cdn-speedtest-speed-' + id).text("Failure").addClass('text-danger');
                        continue;
                    }

                    if(result.duration == Infinity){
                        $('#cdn-speedtest-speed-' + id).text("Timeout").addClass('text-danger');
                        continue;
                    }

                    if(result.speedMbps == 0){
                        $('#cdn-speedtest-speed-' + id).addClass('text-danger');
                    }

                    // Show the speed
                    if(result.speedMBps > 1){
                        $('#cdn-speedtest-speed-' + id).text(result.speedMBps.toFixed(2) + ' MiB/s');
                    } else {
                        $('#cdn-speedtest-speed-' + id).text((result.speedMBps / 1000).toFixed(2)  + ' KiB/s');
                    }

                    if(result.speedMBps > bestSpeed){
                        bestSpeed = result.speedMBps;
                        bestEndpoint = id;
                    }
                }

                if(bestEndpoint){
                    $('#cdn-speedtest-speed-' + bestEndpoint).addClass('text-success');
                }

                $(this).buttonLoader(false);
                $('#cdn-speedtest-status').text('');

            });
        });
    </script>
{% endblock %}
