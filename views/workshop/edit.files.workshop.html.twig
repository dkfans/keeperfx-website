{% extends "workshop/_workshop_layout.html.twig" %}

{% set page_title = 'Edit files - ' ~ workshop_item.name ~ ' - Workshop' %}

{% block workshop_content %}

    {% include 'core/_breadcrumb.html.twig' with {
        items: [
            { label: 'Workshop', url: '/workshop' },
            { label: workshop_item.name, url: '/workshop/item/' ~ workshop_item.id ~ '/' ~ workshop_item.name|slugify },
            { label: 'Edit', url: '/workshop/edit/' ~ workshop_item.id },
            { label: 'Files' }
        ],
        add_back_button: true
    } %}

    <div class="content-box bg-keeper bd-keeper">

        <div class="content-header">
            <div class="d-flex justify-content-between">
                <h2>Edit files: {{ workshop_item.name }}</h2>
            </div>
        </div>

        <div class="content-body">

            <div class="alert bg-dark">
                You can upload a new file here which will be added to the top of the list.
                This list of files is meant for different versions of a specific item.
                <strong>It should not be used to group different creations</strong>.
            </div>

            {# Upload progress bar #}
            <div class="progress mb-3 bg-dark d-none" id="upload-progress-wrapper">
                <div
                    id="upload-progress-bar"
                    class="progress-bar progress-bar-striped progress-bar-animated"
                    role="progressbar"
                    style="width: 0%"
                    aria-valuenow="0"
                    aria-valuemin="0"
                    aria-valuemax="100">
                    0%
                </div>
            </div>

            {# Upload Form #}
            <form action="/workshop/edit/{{ workshop_item.id }}/files" method="POST" enctype="multipart/form-data" id="edit-item-files-form">

                <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}" />
                <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}" />

                <div class="row" style="margin-bottom: 30px;">
                    <div class="col-sm-10">
                        <div class="form-group">
                            <label for="workshop-file">
                                File
                                <span class="text-danger">
                                    *
                                </span>
                            </label>
                            <input type="file" class="form-control" id="workshop-file" name="file" required>
                            <div class="form-group mt-1">
                                <span class="text-muted" style="font-size: 12px;">Maximum filesize: {{ globals.upload_limit.workshop_item.formatted }}</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-2" style="padding-top: 35px;">
                        <button type="submit" class="btn btn-medieval" style="width: 100%;">Upload</button>
                    </div>

                </div>
            </form>


            <table class="table" style="margin-bottom: 0px;" id="files-table">
                <thead>
                    <tr>
                        <th style="width: 80px;"></th>
                        <th>File</th>
                        <th>Filesize</th>
                        <th>Downloads</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for file in workshop_item.files %}
                        <tr>

                            <td style="vertical-align: middle;">

                                {# Move up #}
                                {% if not loop.first %}
                                    <a href="/workshop/edit/{{ workshop_item.id }}/files/{{ file.id }}/move/up/{{ csrf.name }}/{{ csrf.value }}" class="btn btn-medieval" style="padding: 0; padding-top: 6px;">
                                        <ion-icon name="chevron-up-outline" style="font-size: 22px;"></ion-icon>
                                    </a>
                                {% else %}
                                    <div class="btn btn-medieval btn-medieval-gray btn-disabled" style="padding: 0; padding-top: 6px;">
                                        <ion-icon name="chevron-up-outline" style="font-size: 22px;"></ion-icon>
                                    </div>
                                {% endif %}

                                {# Move down #}
                                {% if not loop.last %}
                                    <a href="/workshop/edit/{{ workshop_item.id }}/files/{{ file.id }}/move/down/{{ csrf.name }}/{{ csrf.value }}" class="btn btn-medieval" style="padding: 0; padding-top: 6px;">
                                        <ion-icon name="chevron-down-outline" style="font-size: 22px;"></ion-icon>
                                    </a>
                                {% else %}
                                    <div class="btn btn-medieval btn-medieval-gray btn-disabled" style="padding: 0; padding-top: 6px;">
                                        <ion-icon name="chevron-down-outline" style="font-size: 22px;"></ion-icon>
                                    </div>
                                {% endif %}
                            </td>

                            {# File name #}
                            <td style="vertical-align: middle;">

                                {# Filename anchor #}
                                <a href="/workshop/download/{{ workshop_item.id }}/{{ file.id }}/{{ file.filename|url_encode }}">{{ file.filename }}</a>

                                {# Rename button #}
                                <a href="#" data-rename-id="{{ file.id }}" data-rename-filename="{{ file.filename|url_encode }}" style="position: relative; top: 2px; margin-left: 5px; display:none;" title="Rename">
                                    <ion-icon name="create-outline" aria-hidden="true" style="pointer-events: none;"></ion-icon>
                                </a>

                                {# "Main download" #}
                                {% if loop.first %}
                                    (main download)
                                {% endif %}

                            </td>

                            {# File size #}
                            <td style="vertical-align: middle;">{{ file.size|format_bytes }}</td>

                            {# Downoad count #}
                            <td style="vertical-align: middle;">{{ file.downloadCount }}</td>

                            {# Timestamp #}
                            <td style="vertical-align: middle;">{{ file.createdTimestamp|date('Y-m-d') }}</td>

                            {# Actions #}
                            <td style="vertical-align: middle;">

                                {# Delete button #}
                                <a
                                    href="/workshop/edit/{{ workshop_item.id }}/files/{{ file.id }}/delete/{{ csrf.name }}/{{ csrf.value }}"
                                    class="btn btn-medieval btn-medieval-gray"
                                    onclick="if (confirm('Are you sure you want to delete this file?')){return true;}else{event.stopPropagation(); event.preventDefault();};"
                                >
                                    Delete
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

        </div>
    </div>

{% endblock %}


{% block body_javascript %}
<script>
    var workshop_item = {
        id: {{ workshop_item.id }},
    }
</script>
<script src="{{ asset('js/workshop.js') }}"></script>
<script src="{{ asset('js/workshop.edit-files.js') }}"></script>

<script data-no-instant>
$(function () {

    const $form = $('#edit-item-files-form');
    const $file = $('#workshop-file');
    const $button = $form.find('button[type="submit"]');

    const $progressWrapper = $('#upload-progress-wrapper');
    const $progressBar = $('#upload-progress-bar');

    // Show progress bar
    $progressWrapper.removeClass('d-none');

    // Convert submit button to a normal button
    $button.attr('type', 'button');

    // Handle ajax upload
    $button.on('click', function (e) {

        e.preventDefault()

        if (!$file[0].files.length) {
            if (typeof toastr !== 'undefined') {
                toastr.info('Please select a file first');
            }
            return;
        }

        $button.buttonLoader(true);

        const formData = new FormData($form[0]);

        $progressBar
            .removeClass('bg-success bg-danger')
            .addClass('progress-bar-animated')
            .css('width', '0%')
            .attr('aria-valuenow', 0)
            .text('0%');

        $.ajax({
            url: $form.attr('action'),
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false,

            xhr: function () {

                const xhr = new window.XMLHttpRequest();

                xhr.upload.addEventListener('progress', function (evt) {

                    if (!evt.lengthComputable) return;

                    const percent = Math.round((evt.loaded / evt.total) * 100);

                    $progressBar
                        .css('width', percent + '%')
                        .attr('aria-valuenow', percent)
                        .text(percent + '%');

                });

                return xhr;
            },

            success: function (response) {

                $progressBar
                    .removeClass('progress-bar-animated')
                    .addClass('bg-success')
                    .text('Upload complete');

                const $html = $('<div>').html(response);
                const $newTbody = $html.find('#files-table tbody');
                const $currentTbody = $('#files-table tbody');

                if ($newTbody.length) {
                    $currentTbody.html($newTbody.html());
                }

                $file.val('');
                $button.buttonLoader(false);

                setTimeout(function () {

                    $progressBar
                        .css('width', '0%')
                        .attr('aria-valuenow', 0)
                        .removeClass('bg-success progress-bar-animated')
                        .text('0%');

                }, 800);

                if (typeof toastr !== 'undefined') {
                    toastr.success('File successfully uploaded!');
                }

            },

            error: function () {

                $button.buttonLoader(false);

                $progressBar
                    .removeClass('progress-bar-animated')
                    .addClass('bg-danger')
                    .text('Upload failed');

                if (typeof toastr !== 'undefined') {
                    toastr.error('Upload failed');
                }

            }

        });

    });

});
</script>

{% endblock %}
